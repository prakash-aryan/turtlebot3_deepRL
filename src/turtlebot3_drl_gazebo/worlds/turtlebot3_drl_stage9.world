<?xml version="1.0"?>
<sdf version="1.8">
  <world name="drl_stage9">

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>

    <physics type="ode">
      <real_time_update_rate>1000.0</real_time_update_rate>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
    </physics>

    <scene>
      <shadows>false</shadows>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.7 0.7 0.7 1</background>
    </scene>

    <light type="directional" name="sun">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <include>
      <uri>model://turtlebot3_drl_world/ground_plane</uri>
    </include>

    <include>
      <pose>0 0 0 0 0 0</pose>
      <uri>model://turtlebot3_drl_world/outer_walls_large</uri>
    </include>

    <include>
      <pose>0 0 0 0 0 0</pose>
      <uri>model://turtlebot3_drl_world/inner_walls_large</uri>
    </include>

    <!-- obstacle1 @(2,2) -->
    <include>
      <pose>2 2 0.25 0 0 0</pose>
      <uri>model://turtlebot3_drl_world/obstacle1</uri>
      <name>turtlebot3_drl_obstacle1</name>
      <plugin filename="obstacle_animator" name="turtlebot3_drlnav::ObstacleAnimator">
        <duration>195.0</duration>
        <loop>true</loop>
        <keyframe time="0"   x="0.0"  y="0.0"/>
        <keyframe time="15"  x="-0.5" y="-0.5"/>
        <keyframe time="25"  x="-1.5" y="-0.3"/>
        <keyframe time="55"  x="-4.5" y="0.5"/>
        <keyframe time="85"  x="-4.0" y="-2.7"/>
        <keyframe time="135" x="0.0"  y="-4.5"/>
        <keyframe time="175" x="-1.0" y="-1.0"/>
        <keyframe time="195" x="0.0"  y="0.0"/>
      </plugin>
    </include>

    <!-- obstacle2 @(-2,-2) -->
    <include>
      <pose>-2 -2 0.25 0 0 0</pose>
      <uri>model://turtlebot3_drl_world/obstacle2</uri>
      <name>turtlebot3_drl_obstacle2</name>
      <plugin filename="obstacle_animator" name="turtlebot3_drlnav::ObstacleAnimator">
        <duration>150.0</duration>
        <loop>true</loop>
        <keyframe time="0"   x="0.0"  y="0.0"/>
        <keyframe time="10"  x="1.0"  y="1.0"/>
        <keyframe time="30"  x="3.0"  y="0.0"/>
        <keyframe time="40"  x="4.0"  y="1.0"/>
        <keyframe time="70"  x="2.5"  y="4.2"/>
        <keyframe time="100" x="-0.5" y="4.2"/>
        <keyframe time="130" x="-0.5" y="1.0"/>
        <keyframe time="140" x="0.5"  y="0.5"/>
        <keyframe time="150" x="0.0"  y="0.0"/>
      </plugin>
    </include>

    <!-- obstacle3 @(2,-2) -->
    <include>
      <pose>2 -2 0.25 0 0 0</pose>
      <uri>model://turtlebot3_drl_world/obstacle3</uri>
      <name>turtlebot3_drl_obstacle3</name>
      <plugin filename="obstacle_animator" name="turtlebot3_drlnav::ObstacleAnimator">
        <duration>120.0</duration>
        <loop>true</loop>
        <keyframe time="0"   x="0.0"  y="0.0"/>
        <keyframe time="20"  x="-2.0" y="0.0"/>
        <keyframe time="40"  x="-3.5" y="1.5"/>
        <keyframe time="55"  x="-3.5" y="3.3"/>
        <keyframe time="90"  x="-0.6" y="3.3"/>
        <keyframe time="105" x="-0.6" y="2.0"/>
        <keyframe time="110" x="0.0"  y="2.0"/>
        <keyframe time="120" x="0.0"  y="0.0"/>
      </plugin>
    </include>

    <!-- obstacle4 @(-2,2) -->
    <include>
      <pose>-2 2 0.25 0 0 0</pose>
      <uri>model://turtlebot3_drl_world/obstacle4</uri>
      <name>turtlebot3_drl_obstacle4</name>
      <plugin filename="obstacle_animator" name="turtlebot3_drlnav::ObstacleAnimator">
        <duration>140.0</duration>
        <loop>true</loop>
        <keyframe time="0"   x="0.0"  y="0.0"/>
        <keyframe time="10"  x="0.0"  y="-0.5"/>
        <keyframe time="35"  x="3.0"  y="-0.8"/>
        <keyframe time="40"  x="3.5"  y="-1.3"/>
        <keyframe time="60"  x="4.0"  y="0.0"/>
        <keyframe time="80"  x="3.5"  y="-2.0"/>
        <keyframe time="110" x="2.0"  y="-2.0"/>
        <keyframe time="120" x="1.3"  y="-1.1"/>
        <keyframe time="130" x="0.0"  y="-1.1"/>
        <keyframe time="140" x="0.0"  y="0.0"/>
      </plugin>
    </include>

    <!-- obstacle5 @(0,-2) -->
    <include>
      <pose>0 -2 0.25 0 0 0</pose>
      <uri>model://turtlebot3_drl_world/obstacle5</uri>
      <name>turtlebot3_drl_obstacle5</name>
      <plugin filename="obstacle_animator" name="turtlebot3_drlnav::ObstacleAnimator">
        <duration>110.0</duration>
        <loop>true</loop>
        <keyframe time="0"   x="0.0"  y="0.0"/>
        <keyframe time="20"  x="1.0"  y="2.5"/>
        <keyframe time="35"  x="-1.0" y="2.0"/>
        <keyframe time="55"  x="0.0"  y="0.0"/>
        <keyframe time="65"  x="1.0"  y="0.0"/>
        <keyframe time="75"  x="2.0"  y="1.0"/>
        <keyframe time="85"  x="1.0"  y="2.0"/>
        <keyframe time="95"  x="0.0"  y="2.0"/>
        <keyframe time="110" x="0.0"  y="0.0"/>
      </plugin>
    </include>

    <!-- obstacle6 @(0,2) -->
    <include>
      <pose>0 2 0.25 0 0 0</pose>
      <uri>model://turtlebot3_drl_world/obstacle6</uri>
      <name>turtlebot3_drl_obstacle6</name>
      <plugin filename="obstacle_animator" name="turtlebot3_drlnav::ObstacleAnimator">
        <duration>120.0</duration>
        <loop>true</loop>
        <keyframe time="0"   x="0.0"  y="0.0"/>
        <keyframe time="15"  x="1.0"  y="-1.0"/>
        <keyframe time="40"  x="1.5"  y="-4.0"/>
        <keyframe time="50"  x="1.0"  y="-4.0"/>
        <keyframe time="80"  x="-1.5" y="-2.8"/>
        <keyframe time="100" x="-1.5" y="-0.8"/>
        <keyframe time="110" x="-1.0" y="-0.7"/>
        <keyframe time="120" x="0.0"  y="0.0"/>
      </plugin>
    </include>

  </world>
</sdf>
